# ----------------------------------------------------------
# kr2en-statement — 환경변수 템플릿
# 실제 값을 채워 `.env` 로 복사해서 사용하세요. (.env 는 git 제외)
# Vercel 배포 시에는 동일 키를 Vercel 대시보드 환경변수에 등록하세요.
# ----------------------------------------------------------

# Supabase PostgreSQL (pooled, port 6543)
DATABASE_URL=postgresql://user:password@host:6543/postgres

# Google Gemini (텍스트 + Vision 둘 다 사용)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT 서명 키 — 임의 긴 문자열
JWT_SECRET=replace_with_a_long_random_string

# TossPayments (테스트키 — 운영 시 실제 키로 교체)
TOSS_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY=test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6

# ImageKit (클라이언트 직접 업로드 — 서버는 서명만 발급)
IMAGEKIT_PUBLIC_KEY=public_7Wf9/9pM/Gp/HXOQfUeWh1jmm+Q=
IMAGEKIT_PRIVATE_KEY=private_HUgMWoK582B2ZL8jpGQtksNy//M=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/3um8y0hge

# 페이지당 가격 (KRW)
PRICE_PER_PAGE=2000

# (선택) 로컬 포트
# PORT=3000
