# Supabase pooler endpoint (port 6543). No quotes, no trailing whitespace.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Generate with: openssl rand -hex 48
# Required in production. Falls back to a dev secret only when unset (warns at boot).
JWT_SECRET=replace-with-openssl-rand-hex-48-output

# TossPayments secret key. Use the official test docs key for sandbox flows:
# test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6
TOSS_SECRET_KEY=test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6
